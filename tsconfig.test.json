{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020"],
    "moduleResolution": "Bundler",
    "rootDir": ".",
    "outDir": "dist-types/test",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["test/**/*.ts", "src/**/*.ts"],
  "exclude": ["src/webview/**/*"]
}
